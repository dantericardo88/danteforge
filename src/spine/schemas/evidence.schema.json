{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danteforge.dev/spine/evidence.schema.json",
  "title": "Evidence",
  "version": "1.0.0",
  "description": "Verifiable proof tied to file/test/hash/log. Frozen at v1.0; additive optional fields may ship as 1.x; required-field changes require a 2.0 major bump.",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidenceId", "runId", "artifactId", "kind", "claimSupported", "verificationMethod", "status"],
  "properties": {
    "evidenceId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "pattern": "^run_[0-9]{8}_[0-9]{3}$" },
    "artifactId": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": [
        "test_result",
        "file_inspection",
        "static_analysis",
        "benchmark",
        "hash_verification",
        "human_confirmation"
      ]
    },
    "claimSupported": { "type": "string", "minLength": 1 },
    "verificationMethod": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["passed", "failed", "partial", "missing", "inconclusive", "unsupported"]
    },
    "location": { "type": "string" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "proof": { "type": "object", "description": "Evidence-chain v1 proof bundle for this evidence record." },
    "claimId": { "type": "string" }
  }
}
