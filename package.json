{
  "name": "danteforge",
  "version": "0.9.2",
  "description": "Agentic development CLI - structured specs, execution waves, multi-agent orchestration, skills, gates, TDD, worktrees",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danteforge/danteforge.git"
  },
  "homepage": "https://github.com/danteforge/danteforge",
  "keywords": [
    "cli",
    "agents",
    "agentic",
    "gsd",
    "spec",
    "skills",
    "gates",
    "tdd",
    "worktrees",
    "llm",
    "ai-development"
  ],
  "bin": {
    "danteforge": "dist/index.js",
    "dforge": "dist/index.js"
  },
  "files": [
    ".claude-plugin",
    "dist",
    "src/harvested/dante-agents/skills",
    "agents",
    "commands",
    "hooks",
    "lib",
    "LICENSE",
    "NOTICE.md",
    "THIRD_PARTY_NOTICES.md",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node lib/postinstall.js",
    "build": "tsup",
    "build:dev-sync": "tsup && node scripts/sync-dantecode.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:coverage": "c8 tsx --test tests/**/*.test.ts",
    "check:coverage": "node scripts/check-coverage.mjs",
    "test:design": "tsx --test tests/op-codec.test.ts tests/tool-registry.test.ts tests/design-command.test.ts tests/design-gate.test.ts tests/design-agent.test.ts tests/spatial-decomposer.test.ts tests/token-extractor.test.ts tests/headless-renderer.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:anti-stub": "node scripts/check-anti-stub.mjs",
    "check:plugin-manifests": "node scripts/check-plugin-manifests.mjs",
    "verify": "npm run typecheck && npm run lint && npm run check:anti-stub && npm test",
    "verify:all": "npm run verify && npm run build && npm --prefix vscode-extension run verify",
    "verify:live": "node scripts/check-live-integrations.mjs",
    "check:cli-smoke": "node scripts/check-cli-smoke.mjs",
    "check:repo-hygiene": "node scripts/check-repo-hygiene.mjs",
    "check:repo-hygiene:strict": "node scripts/check-repo-hygiene.mjs --strict-presence",
    "check:third-party-notices": "node scripts/check-third-party-notices.mjs",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "sbom:validate": "node scripts/validate-sbom.mjs",
    "sbom:licenses": "license-checker --summary > sbom/license-report.txt",
    "pack:dry-run": "npm pack --dry-run",
    "release:check:install-smoke": "node scripts/check-package-install-smoke.mjs",
    "release:check": "npm run check:repo-hygiene && npm run verify:all && npm run check:cli-smoke && npm run check:plugin-manifests && npm run release:check:install-smoke && npm run pack:dry-run && npm run check:third-party-notices",
    "release:check:strict": "node scripts/check-release-strict.mjs",
    "release:check:simulated-fresh": "node scripts/check-release-simulated-fresh.mjs",
    "release:proof": "node scripts/check-release-proof.mjs",
    "release:ga": "npm run release:proof && npm run verify:live",
    "prepublishOnly": "npm run verify && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.0",
    "@typescript-eslint/parser": "^8.24.1",
    "c8": "^10.1.3",
    "eslint": "^9.20.0",
    "globals": "^15.15.0",
    "license-checker": "^25.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4"
  }
}
