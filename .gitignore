# Dependencies
node_modules/

# Build output
dist/
vscode-extension/dist/
vscode-extension/.artifacts/
*.vsix

# DanteForge runtime state (per-project, not shared)
.danteforge/
!.danteforge/
.danteforge/*
!.danteforge/agent-guard.json
!.danteforge/agent-ownership.json
!.danteforge/agent-claims/
!.danteforge/agent-claims/.gitkeep
.danteforge/agent-claims/*
!.danteforge/agent-claims/.gitkeep
!.danteforge/dimension-claims/
!.danteforge/dimension-claims/.gitkeep
.danteforge/dimension-claims/*
!.danteforge/dimension-claims/.gitkeep
!.danteforge/score-proposals/
!.danteforge/score-proposals/.gitkeep
.danteforge/score-proposals/*
!.danteforge/score-proposals/.gitkeep
!.danteforge/capability-tests/
!.danteforge/capability-tests/*
# The self-challenge ledger is doctrine-durable ("never silently deleted") — version it.
!.danteforge/challenges.md
!.danteforge/challenges.json
# Track ONLY the canonical competitive matrix — it is the single most valuable
# artifact and must be version-controlled truth (instant recovery via git checkout,
# clobbers visible in diff). Re-ignore the rest of compete/ (universe churn, backups,
# matrix.honest.json) so diffs stay clean.
!.danteforge/compete/
.danteforge/compete/*
!.danteforge/compete/matrix.json
!examples/todo-app/.danteforge/
examples/todo-app/.danteforge/**
!examples/todo-app/.danteforge/AUTOFORGE_GUIDANCE.md
!examples/todo-app/.danteforge/CLARIFY.md
!examples/todo-app/.danteforge/CONSTITUTION.md
!examples/todo-app/.danteforge/PLAN.md
!examples/todo-app/.danteforge/SPEC.md
!examples/todo-app/.danteforge/STATE.yaml
!examples/todo-app/.danteforge/TASKS.md

# Worktrees created by DanteForge agents
.danteforge-worktrees/

# AI tool workspace sidecars — gitignored so they don't trigger rogue-judge detection
# when council members initialise their own workspace dirs during judge sessions.
.openhands/
.continue/
.cursor/

# Logs
*.log

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editors
.vscode/settings.json
*.swp
*.swo
*~

# Secrets (never commit API keys)
.env
.env.*

# DanteForge .op intermediates
*.op.raw
*.op.wip
.danteforge/design-preview.html

# Test runner output (contains local machine paths)
test_output.tap
test_output.txt

# AutoResearch experiment artifacts (human review only, not for commit)
results.tsv
AUTORESEARCH_REPORT.md

# Code coverage reports
coverage/
.tmp-coverage-autoforge/

# Local dev tool caches
.claude/
.cursor/
.dantecode/

# Binary docs (prefer .md)
*.docx

# Test temp directories
.tmp-*/

# DanteForge agent hygiene start
.danteforge/oss-repos/
.danteforge/oss-deep/
.claude/worktrees/
test_output.*
test-output.*
test-run*.log
# DanteForge agent hygiene end
