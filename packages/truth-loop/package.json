{
  "name": "@danteforge/truth-loop",
  "version": "1.0.0",
  "description": "Portable Truth Loop schemas, IDs, and proof helpers for evidence-backed Dante agent workflows.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@danteforge/evidence-chain": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/danteforge.git",
    "directory": "packages/truth-loop"
  },
  "homepage": "https://github.com/dantericardo88/danteforge/tree/main/packages/truth-loop",
  "bugs": {
    "url": "https://github.com/dantericardo88/danteforge/issues"
  },
  "keywords": [
    "truth-loop",
    "agent-verification",
    "evidence",
    "verdicts",
    "danteforge"
  ],
  "publishConfig": {
    "access": "public"
  }
}
